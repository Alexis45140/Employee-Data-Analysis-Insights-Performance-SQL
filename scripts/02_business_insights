-- ==========================================
-- PROJET : Analyse RH - Statistiques par Département
-- OBJECTIF : Identifier les disparités et la structure des coûts
-- ==========================================

USE employees;

-- 1. Classement des départements par coût salarial et effectif

SELECT 
    dept_name AS Departement,
    COUNT(emp_no) AS Nombre_Employes,
    ROUND(AVG(salary), 0) AS Salaire_Moyen,
    SUM(salary) AS Masse_Salariale_Totale
FROM current_employee_stats
GROUP BY dept_name
ORDER BY Salaire_Moyen DESC;

-- 2. Analyse de la Promotion : Temps moyen avant d'atteindre un titre Senior
-- On utilise ici la table originale 'titles' pour comparer avec 'hire_date'
SELECT 
    t.title AS Poste,
    ROUND(AVG(TIMESTAMPDIFF(YEAR, e.hire_date, t.from_date)), 1) AS Annees_Moyennes_Pour_Promotion
FROM employees e
JOIN titles t ON e.emp_no = t.emp_no
WHERE t.title LIKE '%Senior%'
GROUP BY t.title;

-- 3. Identification des "Talents Fidèles" (Top 10 ancienneté avec gros salaires)

SELECT 
    first_name, 
    last_name, 
    dept_name, 
    salary, 
    years_in_company
FROM current_employee_stats
WHERE years_in_company > 15 AND salary > 80000
ORDER BY salary DESC
LIMIT 10;
